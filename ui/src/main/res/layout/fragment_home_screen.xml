<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/favoritesViewPager"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#1A000000" />

    <View
        android:id="@+id/leftEdgeIndicator"
        android:layout_width="16dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:layout_gravity="start"
        android:background="@drawable/left_indicator_background"
        android:visibility="gone" />

    <View
        android:id="@+id/rightEdgeIndicator"
        android:layout_width="16dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:layout_gravity="end"
        android:background="@drawable/right_indicator_background"
        android:visibility="gone" />

    <!-- Индикаторы избранного – точно по высоте панели -->
    <View
        android:id="@+id/leftFavIndicator"
        android:layout_width="16dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/left_indicator_background"
        android:visibility="gone" />

    <View
        android:id="@+id/rightFavIndicator"
        android:layout_width="16dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/right_indicator_background"
        android:visibility="gone" />

</FrameLayout>